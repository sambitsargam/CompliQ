{
    "request_timeout_seconds": 20,
    "max_execution_seconds": 30,
    "max_iterations": 6,
    "max_steps": 12,

    "llm_config": {
        "class": "openai",
        "model_name": "gpt-4o-mini",
        "temperature": 0
    }

    "metadata": {
        "description": "CompliQ compliance analyzer network for SMEs.",
        "sample_queries": [
            "Analyze these policy snippets and return gaps with risk and action plan in JSON."
        ]
    }

    "tools": [
        {
            "name": "ComplianceFrontman",
            "function": {
                "description": "Top-level compliance analyzer. Returns strict JSON only."
            },
            "instructions": """
You are CompliQ's compliance analyzer.

Return strict JSON only with keys:
coverage_percent, risk_score, summary, findings, tasks.

Rules:
1) findings is an array of objects with: title, severity, evidence, recommendation.
2) tasks is an array of objects with: title, owner, priority, due_in_days.
3) severity must be one of: high, medium, low.
4) priority must be one of: P1, P2, P3.
5) Base analysis on framework context in user prompt.
6) No markdown. No extra text outside JSON.
""",
            "max_execution_seconds": 20
        }
    ]
}
