{
    "llm_config": {
        "class": "openai",
        "model_name": "gpt-5.2",
        "temperature": 0
    }

    "metadata": {
        "description": "CompliQ multi-agent compliance analysis network for SMEs.",
        "sample_queries": [
            "Analyze these policy snippets and return gaps with risk and action plan in JSON."
        ]
    }

    "tools": [
        {
            "name": "ComplianceFrontman",
            "function": {
                "description": "Top-level compliance orchestrator. Always return strict JSON output."
            },
            "instructions": """
You are CompliQ's chief compliance orchestrator.

Rules:
1) You must delegate to specialist agents before finalizing.
2) Always return strict JSON with keys:
   coverage_percent, risk_score, summary, findings, tasks.
3) findings is a list of objects with keys:
   title, severity, evidence, recommendation.
4) tasks is a list of objects with keys:
   title, owner, priority, due_in_days.
5) severity values must be: high | medium | low.
6) priority values must be: P1 | P2 | P3.
7) No markdown, no prose outside JSON.
""",
            "tools": [
                "DocParserAgent",
                "RuleMapperAgent",
                "GapDetectorAgent",
                "RiskScorerAgent",
                "ActionPlannerAgent",
                "ReportFormatterTool"
            ]
        },
        {
            "name": "DocParserAgent",
            "function": {
                "description": "Extracts controls, obligations and policy evidence from text."
            },
            "instructions": "Extract policy obligations, ownership, review cadence, incident response, data retention, and access control evidence from the user input."
        },
        {
            "name": "RuleMapperAgent",
            "function": {
                "description": "Maps extracted evidence into compliance control buckets."
            },
            "instructions": "Map extracted evidence to controls: ownership, periodic review, incident handling, retention, access governance."
        },
        {
            "name": "GapDetectorAgent",
            "function": {
                "description": "Identifies missing or weak controls and creates findings."
            },
            "instructions": "Identify missing controls and produce concise finding candidates with severity and recommendations."
        },
        {
            "name": "RiskScorerAgent",
            "function": {
                "description": "Computes compliance coverage and risk score from findings."
            },
            "instructions": "Use RiskScoringTool if needed. Normalize to coverage_percent (0-100) and risk_score (0-100)."
            ,
            "tools": ["RiskScoringTool"]
        },
        {
            "name": "ActionPlannerAgent",
            "function": {
                "description": "Converts findings into execution-ready remediation tasks."
            },
            "instructions": "For each finding produce one task with owner, priority, and due_in_days."
        },
        {
            "name": "RiskScoringTool",
            "function": {
                "description": "Deterministic helper to normalize coverage and risk based on severity counts.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "high": {"type": "integer"},
                        "medium": {"type": "integer"},
                        "low": {"type": "integer"},
                        "total_controls": {"type": "integer"}
                    },
                    "required": ["high", "medium", "low", "total_controls"]
                }
            },
            "class": "compliq.risk_scoring.RiskScoringTool"
        },
        {
            "name": "ReportFormatterTool",
            "function": {
                "description": "Formats a strict JSON compliance report.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "summary": {"type": "string"},
                        "coverage_percent": {"type": "number"},
                        "risk_score": {"type": "number"},
                        "findings": {"type": "array"},
                        "tasks": {"type": "array"}
                    },
                    "required": ["summary", "coverage_percent", "risk_score", "findings", "tasks"]
                }
            },
            "class": "compliq.report_formatter.ReportFormatterTool"
        }
    ]
}
